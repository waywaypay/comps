# Database
DATABASE_URL=postgresql://comps:comps@localhost:5432/comps

# Redis (arq queue)
REDIS_URL=redis://localhost:6379/0

# LLM
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings + rerank
VOYAGE_API_KEY=pa-...
VOYAGE_EMBED_MODEL=voyage-finance-2
VOYAGE_RERANK_MODEL=rerank-2

# API
COMPS_API_HOST=0.0.0.0
COMPS_API_PORT=8000

# Ingest tuning
INGEST_MAX_EXTRACT_CHARS=60000
INGEST_CHUNK_TARGET_TOKENS=400
INGEST_CHUNK_OVERLAP_TOKENS=50
INGEST_EMBED_BATCH=128

# Search tuning
SEARCH_CANDIDATE_LIMIT=100
SEARCH_FUSED_LIMIT=50
SEARCH_RERANK_TOPK=10
SEARCH_RRF_K=60
